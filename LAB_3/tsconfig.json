{
  "compilerOptions": {
    "target": "ES2020",         // Краще вказати конкретну версію для стабільності
    "module": "ESNext",         // Використовуйте сучасні модулі для браузера
    "lib": ["ES2020", "DOM", "DOM.Iterable"], // Дозволяє використовувати об'єкти браузера
    
    "rootDir": "./src",
    "outDir": "./js",           // GitHub Pages зазвичай шукає файли в корені або /docs, але /js теж підходить, якщо в HTML правильний шлях
    
    "strict": true,             // Залишаємо, це "золотий стандарт"
    "sourceMap": true,          // Допоможе дебажити код прямо в браузері
    "skipLibCheck": true,
    "moduleResolution": "bundler" // Найкращий варіант для сучасних проектів
  },
  "include": ["src/**/*"]       // Важливо: вкажіть TS, де саме шукати файли
}